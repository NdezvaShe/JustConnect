APP_NAME="JustConnect"
APP_ENV=production
APP_KEY=base64:generate_a_stable_key_with_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://your-service-name.koyeb.app

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local
PREFERRED_AI=nlp_local
PYTHON_NLP_ENABLED=false

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="JustConnect"

SEED_DEMO_USER=true
DEMO_USER_EMAIL=demo@justconnect.zw
DEMO_USER_PASSWORD=change-this-public-demo-password

APP_NAME="JustConnect"
APP_ENV=local
APP_KEY=base64:REPLACE_WITH_php_artisan_key_generate
APP_DEBUG=true
APP_URL=http://localhost:8501/justconnect/public

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=4306
DB_DATABASE=justconnect
DB_USERNAME=root
DB_PASSWORD=

# AI / NLP Provider
# Set PREFERRED_AI to: openai | gemini | nlp_local
PREFERRED_AI=gemini

# OpenAI (GPT-4o)
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
OPENAI_MODEL=gpt-4o

# Google Gemini
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
REQUIRE_REGISTRATION_EMAIL_VERIFICATION=true

# Cache
CACHE_STORE=database

# Queue
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
DB_QUEUE_TABLE=jobs
DB_FAILED_JOBS_TABLE=failed_jobs

# Filesystem
FILESYSTEM_DISK=local

# Mail
MAIL_MAILER=log
OTP_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS="noreply@justconnect.zw"
MAIL_FROM_NAME="JustConnect"
